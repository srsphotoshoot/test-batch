# Copy this file to .env.dev or .env.prod and fill in your actual values

# Environment
ENVIRONMENT=dev
DEBUG=true

# FastAPI Configuration
FASTAPI_HOST=localhost
FASTAPI_PORT=8000
FASTAPI_BASE_URL=http://localhost:8000

# Gemini API Key (REQUIRED - Get from https://aistudio.google.com/)
SRS_KEY="your_gemini_api_key_here"

# Signup Passkey (REQUIRED - Provide to users for signup)
SIGNUP_PASSKEY="your_secret_passkey_here"

# JWT Secret Key (REQUIRED - Generate a random string)
JWT_SECRET_KEY="your_jwt_secret_key_here"
